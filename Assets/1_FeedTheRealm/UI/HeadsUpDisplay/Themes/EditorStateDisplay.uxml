        <ui:Label text="press [esc] to exit" name="Label" style="translate: 0 75px; -unity-text-align: middle-center; font-size: 18px; color: rgb(255, 255, 255); height: 20px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-outline-color: rgba(0, 0, 0, 0.1); text-shadow: 2.1px 0 0 rgba(0, 0, 0, 0); -unity-text-outline-width: 0.5px;"/>
    </ui:VisualElement>
