<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/1_FeedTheRealm/UI/Common/Themes/MenuStyles.uss?fileID=7433441132597879392&amp;guid=6b7e654547706d266a894867f8097fbd&amp;type=3#MenuStyles"/>
    <ui:VisualElement name="Root" class="menu-root">
        <ui:VisualElement name="Container" class="container" style="width: 45%; min-width: 400px; max-width: 700px; height: auto; min-height: 260px;">
            <ui:VisualElement name="Panel" class="menu-panel" style="flex-direction: column; flex-grow: 1;">
                <ui:Button text="✕" name="Close" class="menu-close-btn"/>
                <ui:VisualElement name="Header" class="menu-header">
                    <ui:Label text="Settings" name="Title" class="menu-header-label"/>
                </ui:VisualElement>
                <ui:VisualElement name="Content" style="flex-direction: column; margin-top: 18px;">
                    <ui:Toggle label="Fullscreen" toggle-on-label-click="true" value="true" name="FullscreenToggle" class="menu-toggle" style="font-size: 20px;"/>
                    <ui:Button text="Clear Cache" name="ClearCacheButton" class="menu-secondary-btn" style="margin-top: 14px;"/>
                    <ui:Label text="" name="CacheStatusLabel" class="menu-field-label" style="font-size: 15px; margin-top: 8px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
